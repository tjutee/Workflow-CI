name: CustomerSegmentation-MLflow

conda_env: conda.yaml

entry_points:
  train:
    parameters:
      dataset_path:
        description: "Path ke dataset yang sudah dipreprocess"
        type: string
        default: "Customer-Segmentation_preprocessing.csv"
      n_clusters:
        description: "Jumlah cluster untuk KMeans"
        type: int
        default: 3
      random_state:
        description: "Random state untuk reproducibility"
        type: int
        default: 42
    command: "python modelling.py --dataset_path {dataset_path} --n_clusters {n_clusters} --random_state {random_state}"
